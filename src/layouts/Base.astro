---
import '@fontsource/instrument-serif';
import '@fontsource/jetbrains-mono';
import '@fontsource-variable/public-sans';
import '../styles/global.css';
import serifExtWoff2 from '@fontsource/instrument-serif/files/instrument-serif-latin-ext-400-normal.woff2?url';
import serifWoff2 from '@fontsource/instrument-serif/files/instrument-serif-latin-400-normal.woff2?url';
import monoExtWoff2 from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-ext-400-normal.woff2?url';
import monoWoff2 from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import sansExtWoff2 from '@fontsource-variable/public-sans/files/public-sans-latin-ext-wght-normal.woff2?url';
import sansWoff2 from '@fontsource-variable/public-sans/files/public-sans-latin-wght-normal.woff2?url';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { email, github, linkedin } from '../data/site';
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
  noindex?: boolean;
}

const { lang, noindex = false } = Astro.props;
const t = useTranslations(lang);

// Czech glyphs (ě š č ř ž …) live in latin-ext — preload it only where it is used
const fontPreloads =
  lang === 'cs'
    ? [serifWoff2, serifExtWoff2, monoWoff2, monoExtWoff2, sansWoff2, sansExtWoff2]
    : [serifWoff2, monoWoff2, sansWoff2];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{t('meta.title')}</title>
    <meta name="description" content={t('meta.description')} />
    <meta name="author" content="Josef Kvapil" />
    {noindex && <meta name="robots" content="noindex" />}
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf8f4" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#121110" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:title" content={t('meta.title')} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'cs' ? 'cs_CZ' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'cs' ? 'en_US' : 'cs_CZ'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t('meta.title')} />
    <meta name="twitter:description" content={t('meta.description')} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {fontPreloads.map((href) => <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />)}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Josef Kvapil',
        jobTitle: 'Frontend Architect',
        email: `mailto:${email}`,
        url: Astro.site?.toString(),
        sameAs: [github, linkedin],
        worksFor: { '@type': 'Organization', name: 'Trask' },
        address: { '@type': 'PostalAddress', addressLocality: 'Liberec', addressCountry: 'CZ' },
      })}
    />
    <link rel="alternate" hreflang="en" href={getAbsoluteLocaleUrl('en', '')} />
    <link rel="alternate" hreflang="cs" href={getAbsoluteLocaleUrl('cs', '')} />
    <link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('en', '')} />
    <script is:inline>
      (() => {
        let stored = null;
        try {
          stored = localStorage.getItem('theme');
        } catch {}
        const theme =
          stored === 'dark' || stored === 'light'
            ? stored
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    {
      import.meta.env.PROD && (
        <script
          is:inline
          type="module"
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon='{"token": "957b5f60eecf4e2f997b551464b1b33f"}'
        />
      )
    }
  </head>
  <body>
    <a
      href="#main-content"
      class="label-mono sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-10 focus:bg-paper focus:px-3 focus:py-2"
    >
      {t('nav.skip')}
    </a>
    <slot />
    <script>
      import { email, github } from '../data/site';

      /* Console art — the JK monogram (see Logo.astro), third bar in accent.
         Left/right of the accent bar per row; row 4 is the gap in the K. */
      const left = ['    ███ ', '    ███ ', '    ███ ', '    ███ ', '███ ███ ', '███ ███ ', '███ ███ '];
      const right = [' ███', ' ███', ' ███', '', ' ███', ' ███', ' ███'];
      const mono = 'font-family:ui-monospace,monospace';
      const accent = `${mono};color:#e8442e`;
      console.log(
        `\n${left.map((l, i) => `%c${l}%c███%c${right[i]}`).join('\n')}\n`,
        ...left.flatMap(() => [mono, accent, mono]),
      );
      console.log(
        `%c0 errors, 0 warnings, 1 hidden message. You found it.\n\nLet's talk → ${email}\nReceipts   → ${github}\n\nP.S. you read consoles for fun — you'll want this: ↑ ↑ ↓ ↓ ← → ← → B A`,
        mono,
      );

      /* Konami code → dynamic-import the easter egg (src/scripts/vibecoding.ts).
         The payload lives in its own chunk and is only fetched the moment
         someone actually finishes the code. */
      const KONAMI = [
        'ArrowUp',
        'ArrowUp',
        'ArrowDown',
        'ArrowDown',
        'ArrowLeft',
        'ArrowRight',
        'ArrowLeft',
        'ArrowRight',
        'b',
        'a',
      ];
      let progress = 0;

      addEventListener('keydown', (e) => {
        const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
        progress = key === KONAMI[progress] ? progress + 1 : key === KONAMI[0] ? 1 : 0;
        if (progress === KONAMI.length) {
          progress = 0;
          import('../scripts/vibecoding').then((m) => m.show());
        }
      });
    </script>
  </body>
</html>
