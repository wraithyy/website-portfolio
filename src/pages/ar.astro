---
import Base from '../layouts/Base.astro';
import { email, github, linkedin } from '../data/site';

// Standalone utility route reached only by scanning the printed card's QR.
// noindex. Copy is inline + bilingual (CZ primary · EN) rather than in
// i18n/ui.ts — a tiny single-purpose page, not part of the localized site flow.
---

<Base lang="en" noindex>
  <main id="main-content" class="ar">
    <div id="ar-container" class="ar__stage"></div>

    <!-- AR supported: intro / start -->
    <div id="ar-intro" class="ar__overlay" hidden>
      <span class="label-mono ar__kicker">Josef Kvapil · AR</span>
      <p class="ar__lead">Namiř foťák na zadní stranu vizitky.</p>
      <p class="ar__sub">Point your camera at the back of the card.</p>
      <button id="ar-start" class="ar__btn" type="button">Spustit kameru · Start</button>
      <p class="ar__fine label-mono">Kamera zůstává v prohlížeči — nic se nikam neposílá.</p>
      <a href="/josef.vcf" download class="ar__link label-mono" data-ev="contact_save">
        Uložit kontakt · Save contact
      </a>
    </div>

    <!-- loading the AR engine -->
    <div id="ar-loading" class="ar__overlay" hidden>
      <div class="ar__spinner" aria-hidden="true"></div>
      <p class="ar__sub">Načítám AR… · Loading…</p>
    </div>

    <!-- scanning: shown after camera starts, until the card is found -->
    <div id="ar-scan" class="ar__scan" hidden>
      <div class="ar__reticle" aria-hidden="true"></div>
      <p class="ar__scan-copy label-mono">Namiř na vizitku · dobré světlo, ~20 cm</p>
    </div>

    <div id="ar-hint" class="ar__hint label-mono" hidden>
      Drž vizitku v záběru · konec: zmáčkni tlačítko
    </div>

    <button id="ar-skip" class="ar__skip label-mono" type="button" hidden>Přeskočit →</button>

    <!-- shown once the story completes: the real choice of actions (vCard-first) -->
    <div id="ar-cta" class="ar__actions" hidden>
      <a href="/josef.vcf" download class="ar__btn" data-ev="contact_save">Uložit kontakt</a>
      <a href="/" class="ar__btn ar__btn--ghost" data-ev="cta_web">jkvapil.cz</a>
      <button id="ar-replay" class="ar__btn ar__btn--ghost" type="button">Znovu ↺</button>
    </div>

    <div id="ar-toast" class="ar__toast label-mono" role="status" hidden>Kontakt stažen ✓</div>

    <!-- no camera / unsupported / in-app webview / denied: a real contact card -->
    <div id="ar-fallback" class="ar__overlay" hidden>
      <span class="label-mono ar__kicker">Josef Kvapil</span>
      <p class="ar__lead">Frontend architekt</p>
      <p id="ar-fallback-msg" class="ar__sub"></p>
      <div class="ar__actions ar__actions--static">
        <a href="/josef.vcf" download class="ar__btn" data-ev="contact_save">Uložit kontakt</a>
        <a href={`mailto:${email}`} class="ar__btn ar__btn--ghost" data-ev="cta_mail">Napiš mi</a>
        <a href={linkedin} class="ar__btn ar__btn--ghost" rel="noopener" target="_blank">LinkedIn</a>
        <a href={github} class="ar__btn ar__btn--ghost" rel="noopener" target="_blank">GitHub</a>
        <a href="/" class="ar__btn ar__btn--ghost">jkvapil.cz</a>
      </div>
      <button id="ar-copy" class="ar__link label-mono" type="button" hidden>Zkopírovat odkaz</button>
    </div>
  </main>
</Base>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    overflow: hidden;
    overscroll-behavior: none;
  }
  .ar {
    /* Hardcode ink/paper here: the global tokens SWAP in dark theme, which
       flipped this page to a light background (looked like a letterbox / washed
       camera). The AR route is always ink, regardless of the visitor's theme. */
    --ink: #121110;
    --paper: #e8e4dc;
    --muted: #918c84;
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh; /* fallback */
    height: 100dvh; /* full height on mobile Safari */
    background: var(--ink);
    color: var(--paper);
    overflow: hidden;
  }
  .ar__stage {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  /* mind-ar sizes & centres the video/canvas itself — don't override it. */
  .ar__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    padding: max(2rem, env(safe-area-inset-top)) max(2rem, env(safe-area-inset-right))
      max(2rem, env(safe-area-inset-bottom)) max(2rem, env(safe-area-inset-left));
    background: var(--ink);
  }
  .ar__kicker {
    color: var(--accent);
  }
  .ar__lead {
    font-family: var(--font-display, 'Instrument Serif', serif);
    font-size: clamp(1.75rem, 6vw, 2.75rem);
    line-height: 1.05;
    margin: 0;
    max-width: 18ch;
  }
  .ar__sub {
    color: var(--muted);
    margin: 0;
    font-size: 0.95rem;
    max-width: 30ch;
  }
  .ar__btn {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--accent);
    border: none;
    padding: 0.7rem 1.3rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
  }
  .ar__btn:hover {
    opacity: 0.92;
  }
  .ar__btn--ghost {
    background: transparent;
    color: var(--paper);
    border: 1px solid color-mix(in srgb, var(--paper) 35%, transparent);
  }
  .ar__link {
    color: var(--muted);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.75rem;
  }
  /* completion action cluster — floats over the live AR at the bottom */
  .ar__actions {
    position: absolute;
    left: 50%;
    bottom: max(1.5rem, env(safe-area-inset-bottom));
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    max-width: min(92vw, 30rem);
    padding: 0 1rem;
  }
  /* scrim so ghost buttons stay legible over a bright camera feed */
  .ar__actions:not(.ar__actions--static)::before {
    content: '';
    position: absolute;
    inset: -2rem -1rem -3rem;
    background: linear-gradient(to top, color-mix(in srgb, var(--ink) 85%, transparent), transparent);
    z-index: -1;
    pointer-events: none;
  }
  .ar__actions--static {
    position: static;
    transform: none;
    margin-top: 0.5rem;
  }
  .ar__hint {
    position: absolute;
    left: 50%;
    bottom: max(1.5rem, env(safe-area-inset-bottom));
    transform: translateX(-50%);
    z-index: 2;
    color: var(--paper);
    background: color-mix(in srgb, var(--ink) 70%, transparent);
    padding: 0.5rem 0.9rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
  }
  .ar__spinner {
    width: 2rem;
    height: 2rem;
    border: 2px solid color-mix(in srgb, var(--paper) 25%, transparent);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: ar-spin 0.8s linear infinite;
  }
  @keyframes ar-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .ar__fine {
    color: var(--muted);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    max-width: 26ch;
    margin: 0;
  }
  /* scanning state: reticle + copy, over the live camera */
  .ar__scan {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    pointer-events: none;
  }
  .ar__reticle {
    width: min(62vw, 20rem);
    aspect-ratio: 85 / 55;
    border: 1.5px solid color-mix(in srgb, var(--paper) 70%, transparent);
    position: relative;
    animation: ar-breathe 1.8s ease-in-out infinite;
  }
  .ar__reticle::before,
  .ar__reticle::after {
    content: '';
    position: absolute;
    width: 1.4rem;
    height: 1.4rem;
    border: 2px solid var(--accent);
  }
  .ar__reticle::before {
    top: -2px;
    left: -2px;
    border-right: none;
    border-bottom: none;
  }
  .ar__reticle::after {
    bottom: -2px;
    right: -2px;
    border-left: none;
    border-top: none;
  }
  .ar__scan-copy {
    color: var(--paper);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: color-mix(in srgb, var(--ink) 70%, transparent);
    padding: 0.5rem 0.9rem;
  }
  @keyframes ar-breathe {
    0%,
    100% {
      opacity: 0.55;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.02);
    }
  }
  .ar__skip {
    position: absolute;
    top: max(1rem, env(safe-area-inset-top));
    right: max(1rem, env(safe-area-inset-right));
    z-index: 3;
    color: var(--paper);
    background: color-mix(in srgb, var(--ink) 65%, transparent);
    border: none;
    padding: 0.5rem 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .ar__toast {
    position: absolute;
    left: 50%;
    top: max(1.2rem, env(safe-area-inset-top));
    transform: translateX(-50%);
    z-index: 4;
    background: var(--accent);
    color: var(--paper);
    padding: 0.5rem 0.9rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  @media (prefers-reduced-motion: reduce) {
    .ar__spinner {
      animation-duration: 2s;
    }
    .ar__reticle {
      animation: none;
    }
  }
</style>

<script>
  type ARHandle = { stop: () => void; replay: () => void; skip: () => void };
  type AROpts = { onComplete?: () => void; onFound?: () => void; onLost?: () => void };

  const $ = (id: string) => document.getElementById(id)!;
  const intro = $('ar-intro');
  const loading = $('ar-loading');
  const scan = $('ar-scan');
  const hint = $('ar-hint');
  const skipBtn = $('ar-skip') as HTMLButtonElement;
  const cta = $('ar-cta');
  const toast = $('ar-toast');
  const fallback = $('ar-fallback');
  const fallbackMsg = $('ar-fallback-msg');
  const startBtn = $('ar-start') as HTMLButtonElement;
  const replayBtn = $('ar-replay') as HTMLButtonElement;
  const copyBtn = $('ar-copy') as HTMLButtonElement;
  const container = $('ar-container');

  // lightweight funnel hook — dispatches a window event per step. A real sink
  // (Cloudflare Pages Function) can listen/forward later; harmless until then.
  const track = (name: string) =>
    dispatchEvent(new CustomEvent('ar:event', { detail: { name } }));

  const show = (el: HTMLElement) => (el.hidden = false);
  const hide = (el: HTMLElement) => (el.hidden = true);

  let toastTimer = 0;
  const flashToast = () => {
    show(toast);
    clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => hide(toast), 2200);
  };
  for (const el of document.querySelectorAll<HTMLElement>('[data-ev]')) {
    el.addEventListener('click', () => {
      track(el.dataset.ev!);
      if (el.dataset.ev === 'contact_save') flashToast();
    });
  }

  const isWebview = /(FBAN|FBAV|Instagram|LinkedInApp|Messenger|\bLine\/|Twitter|TikTok|Snapchat|GSA)/i.test(
    navigator.userAgent,
  );
  const hasCamera = window.isSecureContext && !!navigator.mediaDevices?.getUserMedia;
  const hasWebGL = (() => {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  })();

  const showFallback = (msg: string, offerCopy = false) => {
    hide(intro);
    hide(loading);
    hide(scan);
    hide(hint);
    hide(skipBtn);
    hide(cta);
    fallbackMsg.textContent = msg;
    copyBtn.hidden = !offerCopy;
    show(fallback);
  };

  if (isWebview) {
    // in-app browsers (IG/LinkedIn/…) block the camera — send them to a real browser
    track('unsupported_webview');
    showFallback(
      'AR potřebuje Safari/Chrome — otevři tam jkvapil.cz/ar. Zatím si ulož kontakt. · Open jkvapil.cz/ar in Safari/Chrome for AR.',
      true,
    );
  } else if (!hasCamera || !hasWebGL) {
    track('unsupported');
    showFallback(
      'Tvůj prohlížeč AR nepodporuje — ale kontakt si ulož. · AR unsupported here — grab the contact.',
    );
  } else {
    show(intro);
    let done = false; // story completed at least once
    startBtn.addEventListener('click', async () => {
      startBtn.disabled = true;
      hide(intro);
      show(loading);
      track('ar_start');
      try {
        const mod = (await import('../scripts/ar')) as {
          start: (c: HTMLElement, o?: AROpts) => Promise<ARHandle>;
        };
        const handle = await mod.start(container, {
          onFound: () => {
            hide(scan);
            if (done) return;
            show(hint);
            show(skipBtn);
          },
          onLost: () => {
            if (done) return;
            hide(hint);
            hide(skipBtn);
            (scan.querySelector('.ar__scan-copy') as HTMLElement).textContent =
              'Ztraceno — namiř znovu · Reframe the card';
            show(scan);
          },
          onComplete: () => {
            done = true;
            track('story_complete');
            hide(hint);
            hide(skipBtn);
            hide(scan);
            show(cta);
          },
        });
        hide(loading);
        show(scan); // scanning until the card is found
        skipBtn.addEventListener('click', () => handle.skip());
        replayBtn.addEventListener('click', () => {
          done = false;
          handle.replay();
          hide(cta);
          show(hint);
          show(skipBtn);
        });
      } catch (e) {
        const err = e as { name?: string; message?: string };
        showFallback(
          err?.name === 'NotAllowedError'
            ? 'Kamera odepřena. Povol ji v prohlížeči a načti znovu. · Camera denied — allow it and reload.'
            : 'Kameru se nepodařilo spustit. · Could not start the camera.',
        );
      }
    });
  }

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(location.href);
      copyBtn.textContent = 'Zkopírováno ✓';
    } catch {
      copyBtn.textContent = location.href;
    }
  });
</script>
