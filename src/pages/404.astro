---
import Base from '../layouts/Base.astro';
---

<Base lang="en" noindex>
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-(--spacing-gutter)">
    <header class="py-6">
      <a href="/" class="label-mono">Josef Kvapil</a>
    </header>
    <main class="flex grow flex-col justify-center pb-24">
      <p class="label-mono text-accent">404 — not found</p>
      <h1 class="mt-5 max-w-3xl font-display text-display text-balance">
        This route was never typed.
      </h1>
      <p class="mt-8 max-w-md text-lg leading-relaxed text-muted">
        The compiler would have caught this. Let’s get you back to a page that exists.
      </p>
      <p class="mt-10">
        <a
          href="/"
          class="label-mono inline-block border border-ink px-6 py-3 transition-colors hover:border-accent hover:text-accent"
        >
          ← Back home
        </a>
      </p>
    </main>
  </div>
</Base>
