---
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stackGroups: Array<{ label: Record<Lang, string>; items: string }> = [
  {
    label: { en: 'daily', cs: 'denně' },
    items: 'React · TypeScript · TanStack · Hono · Drizzle · Astro · MUI · Vite · Biome',
  },
  {
    label: { en: 'environment', cs: 'prostředí' },
    items: 'vim · tmux · Claude Code · Docker · GitLab CI · Jenkins · OpenShift',
  },
  {
    label: { en: 'I find my way in', cs: 'zorientuju se v' },
    items: 'Angular · Java · Rust · Go · Elixir · Gleam',
  },
];

const employers: Array<{ years: Record<Lang, string>; name: string; role: Record<Lang, string> }> = [
  {
    years: { en: '2021 — now', cs: '2021 — teď' },
    name: 'Trask',
    role: {
      en: 'senior frontend developer → architect & team lead — banking, energy, insurance',
      cs: 'senior frontend vývojář → architekt & team lead — bankovnictví, energetika, pojišťovnictví',
    },
  },
  {
    years: { en: '2019 — 21', cs: '2019 — 21' },
    name: 'Lundegaard',
    role: {
      en: 'JavaScript developer — React & Angular on large corporate applications',
      cs: 'JavaScript vývojář — React a Angular na velkých korporátních aplikacích',
    },
  },
  {
    years: { en: '2018 — 19', cs: '2018 — 19' },
    name: 'Trask',
    role: { en: 'JavaScript developer — Angular, JSP, a bit of Java', cs: 'JavaScript vývojář — Angular, JSP, občas Java' },
  },
  {
    years: { en: '2015 — 17', cs: '2015 — 17' },
    name: 'C26.cz',
    role: {
      en: 'programmer — PHP, C, jQuery, and my first clients',
      cs: 'programátor — PHP, C, jQuery a první klienti',
    },
  },
];
---

<section id="about" class="mx-auto max-w-6xl scroll-mt-20 px-(--spacing-gutter) py-(--spacing-section)">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,5fr)_minmax(0,7fr)]">
    <div>
      <p class="label-mono text-accent">{t('about.label')}</p>
      <h2 class="mt-4 font-display text-title text-balance">{t('about.title')}</h2>
    </div>
    <div>
      <p class="max-w-xl text-lg leading-relaxed text-muted">{t('about.bio')}</p>
      <p class="mt-5 max-w-xl font-display text-2xl leading-snug text-balance">{t('about.aiStance')}</p>
      <p class="label-mono mt-10 text-muted">{t('about.stackLabel')}</p>
      <dl class="mt-3 max-w-xl space-y-2">
        {
          stackGroups.map((group) => (
            <div class="grid gap-x-6 gap-y-0.5 sm:grid-cols-[7rem_minmax(0,1fr)]">
              <dt class="label-mono pt-0.5 text-muted">{group.label[lang]}</dt>
              <dd class="font-mono text-sm">{group.items}</dd>
            </div>
          ))
        }
      </dl>
      <p class="label-mono mt-10 text-muted">{t('about.employersLabel')}</p>
      <ol class="mt-3 max-w-xl border-t border-hairline">
        {
          employers.map((job) => (
            <li class="grid gap-x-6 gap-y-0.5 border-b border-hairline py-3 sm:grid-cols-[7rem_minmax(0,1fr)]">
              <span class="label-mono pt-0.5 text-muted">{job.years[lang]}</span>
              <div>
                <span class="font-mono text-sm">{job.name}</span>
                <span class="block text-sm text-muted">{job.role[lang]}</span>
              </div>
            </li>
          ))
        }
      </ol>
      <p class="label-mono mt-8 text-muted">{t('about.factsLabel')}</p>
      <p class="label-mono mt-2 max-w-xl text-muted">{t('about.facts')}</p>
    </div>
  </div>
</section>
