---
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: 'GitHub', href: 'https://github.com/wraithyy', handle: '@wraithyy' },
  { label: 'Email', href: 'mailto:josef0kvapil@gmail.com', handle: 'josef0kvapil@gmail.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/josef-kvapil', handle: 'josef-kvapil' },
];
---

<section id="contact" class="mx-auto max-w-6xl scroll-mt-12 px-(--spacing-gutter) py-(--spacing-section)">
  <p class="label-mono text-accent">{t('contact.label')}</p>
  <h2 class="mt-4 font-display text-title">{t('contact.title')}</h2>
  <p class="mt-6 max-w-md text-lg leading-relaxed text-muted">{t('contact.body')}</p>

  <ul class="mt-12 border-t border-hairline">
    {
      links.map((link) => (
        <li class="border-b border-hairline">
          <a
            href={link.href}
            class="group flex items-baseline justify-between gap-6 py-5"
            {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class="label-mono text-muted">{link.label}</span>
            <span class="font-mono text-sm transition-colors group-hover:text-accent">
              {link.handle} <span aria-hidden="true">↗</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <!-- The closing loop: the next sketch is the visitor's project -->
  <div class="mt-20 text-center">
    <a
      href="mailto:josef0kvapil@gmail.com"
      class="next-sketch label-mono inline-flex min-h-11 items-center px-8 normal-case"
    >
      btn / {lang === 'cs' ? 'váš-projekt' : 'your-project'}
    </a>
    <p class="label-mono mt-4 text-muted">
      {lang === 'cs' ? 'další výkres může být váš' : 'the next sketch could be yours'}
    </p>
  </div>
</section>

<style>
  .next-sketch {
    border: 1.5px dashed var(--accent);
    color: var(--accent);
    transition:
      border-color 250ms ease,
      border-style 250ms ease,
      color 250ms ease,
      background-color 250ms ease;
  }
  .next-sketch:hover,
  .next-sketch:focus-visible {
    border-style: solid;
    border-color: var(--accent);
    background: var(--accent);
    color: var(--paper);
  }
  .next-sketch:active {
    transform: translateY(1px);
  }
</style>
