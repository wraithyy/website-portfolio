---
import { email, github, linkedin } from '../data/site';
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: 'GitHub', href: github, handle: '@wraithyy' },
  { label: 'Email', href: `mailto:${email}`, handle: email },
  { label: 'LinkedIn', href: linkedin, handle: 'josef-kvapil' },
  { label: 'CV', href: '/cv-josef-kvapil.pdf', handle: t('contact.cv') },
];
---

<section id="contact" class="mx-auto max-w-6xl scroll-mt-20 px-(--spacing-gutter) py-(--spacing-section)">
  <p class="label-mono text-accent">{t('contact.label')}</p>
  <h2 class="mt-4 font-display text-title">{t('contact.title')}</h2>
  <p class="mt-6 max-w-md text-lg leading-relaxed text-muted">{t('contact.body')}</p>

  <ul class="mt-12 border-t border-hairline">
    {
      links.map((link) => (
        <li class="border-b border-hairline">
          <a
            href={link.href}
            class="group flex items-baseline justify-between gap-6 py-5"
            {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <span class="label-mono text-muted">{link.label}</span>
            <span class="font-mono text-sm transition-colors group-hover:text-accent">
              {link.handle} <span aria-hidden="true">↗</span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
  <p class="label-mono mt-5 text-muted">{t('contact.meta')}</p>

  <!-- The closing loop: the next sketch is the visitor's project -->
  <div class="mt-20 text-center">
    <a
      href={`mailto:${email}`}
      class="label-mono inline-flex min-h-11 items-center border-[1.5px] border-dashed border-accent px-8 text-accent normal-case transition-colors hover:border-solid hover:bg-accent hover:text-paper focus-visible:border-solid focus-visible:bg-accent focus-visible:text-paper active:translate-y-px"
    >
      {t('contact.ctaLabel')}
    </a>
    <p class="label-mono mt-4 text-muted">{t('contact.ctaNote')}</p>
  </div>
</section>
