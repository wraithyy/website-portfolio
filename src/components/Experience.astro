---
import { capabilities } from '../data/capabilities';
import { type Lang, useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="experience" class="mx-auto max-w-6xl scroll-mt-12 px-(--spacing-gutter) py-(--spacing-section)">
  <p class="label-mono text-accent">{t('exp.label')}</p>
  <h2 class="mt-4 font-display text-title">{t('exp.title')}</h2>

  <ol class="mt-12 border-t border-hairline">
    {
      capabilities.map((item, i) => (
        <li class="group grid gap-3 border-b border-hairline py-9 lg:grid-cols-[3rem_minmax(0,5fr)_minmax(0,6fr)] lg:gap-8">
          <span class="label-mono pt-2 text-muted transition-colors group-hover:text-accent">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="font-display text-title text-balance">{item.title[lang]}</h3>
          <div>
            <p class="max-w-xl leading-relaxed text-muted">{item.body[lang]}</p>
            <p class="label-mono mt-4 text-muted">{item.proof[lang]}</p>
          </div>
        </li>
      ))
    }
  </ol>
  <p class="label-mono mt-6 text-muted">{t('exp.note')}</p>
</section>
