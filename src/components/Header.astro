---
import { type Lang, type UiKey, useTranslations } from '../i18n/ui';
import Logo from './Logo.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const langTarget = lang === 'en' ? '/cs/' : '/';
const homeHref = lang === 'en' ? '/' : '/cs/';

const items: { href: string; key: UiKey }[] = [
  { href: '#experience', key: 'nav.experience' },
  { href: '#projects', key: 'nav.projects' },
  { href: '#about', key: 'nav.about' },
  { href: '#contact', key: 'nav.contact' },
];
const num = (i: number) => String(i + 1).padStart(2, '0');
const itemCount = String(items.length).padStart(2, '0');
---

<!-- Full masthead: static, scrolls away with the page -->
<header class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-(--spacing-gutter) py-6">
  <a href={homeHref} class="flex items-center gap-3 text-ink no-underline whitespace-nowrap">
    <Logo class="h-7 w-auto" />
    <span class="font-display text-2xl leading-none">Josef Kvapil</span>
  </a>

  <!-- Desktop: numbered index inline -->
  <nav class="hidden items-baseline gap-x-7 md:flex" aria-label="Main">
    {
      items.map((item, i) => (
        <a href={item.href} class="label-mono text-muted transition-colors hover:text-accent">
          <span class="num text-accent" aria-hidden="true">{num(i)}</span>
          {t(item.key)}
        </a>
      ))
    }
    <a
      href={langTarget}
      hreflang={lang === 'en' ? 'cs' : 'en'}
      lang={lang === 'en' ? 'cs' : 'en'}
      class="label-mono text-muted transition-colors hover:text-accent"
    >
      {t('nav.langSwitch')}
    </a>
    <button
      type="button"
      data-theme-toggle
      class="label-mono cursor-pointer text-muted transition-colors hover:text-accent"
      aria-pressed="false"
    >
      <span class="dark:hidden">dark</span>
      <span class="hidden dark:inline">light</span>
      <span class="sr-only">{t('nav.themeToggle')}</span>
    </button>
  </nav>

  <!-- Mobile: index toggle -->
  <button
    type="button"
    data-nav-open
    class="label-mono cursor-pointer text-muted transition-colors hover:text-accent md:hidden"
    aria-expanded="false"
    aria-controls="nav-index"
  >
    {t('nav.menu')} / <span class="text-accent">{itemCount}</span>
  </button>
</header>

<!-- Slim brand strip: fixed overlay, slides in after the masthead scrolls away.
     Fixed (not sticky) on purpose — it must never change the page's layout height. -->
<div
  id="brandbar"
  class="fixed inset-x-0 top-0 z-40 -translate-y-full border-b border-hairline bg-paper transition-transform duration-250 ease-[cubic-bezier(0.16,1,0.3,1)] data-visible:translate-y-0 motion-reduce:transition-none"
>
  <div class="mx-auto flex h-(--brandbar-h) max-w-6xl items-center justify-between gap-6 px-(--spacing-gutter)">
    <a href={homeHref} class="flex items-center gap-2.5 text-ink no-underline whitespace-nowrap">
      <Logo class="h-4.5 w-auto" />
      <span class="font-display text-[1.0625rem] leading-none">Josef Kvapil</span>
    </a>
    <nav class="hidden items-baseline gap-x-6 md:flex" aria-label="Main">
      {
        items.map((item, i) => (
          <a href={item.href} class="label-mono text-muted transition-colors hover:text-accent">
            <span class="num text-accent" aria-hidden="true">{num(i)}</span>
            {t(item.key)}
          </a>
        ))
      }
    </nav>
    <button
      type="button"
      data-nav-open
      class="cursor-pointer text-muted transition-colors hover:text-accent md:hidden"
      aria-expanded="false"
      aria-controls="nav-index"
      aria-label={t('nav.menu')}
    >
      <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M0 1.5 H18 M0 7 H18 M0 12.5 H18" stroke-dasharray="3.5 2.5"></path>
      </svg>
    </button>
  </div>
</div>

<!-- Mobile: fullscreen drawing index -->
<div
  id="nav-index"
  role="dialog"
  aria-modal="true"
  aria-label={t('nav.menu')}
  class="fixed inset-0 z-50 hidden flex-col bg-paper md:hidden!"
>
  <div
    class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6 px-(--spacing-gutter) py-6"
  >
    <a href={homeHref} class="flex items-center gap-3 text-ink no-underline whitespace-nowrap">
      <Logo class="h-7 w-auto" />
      <span class="font-display text-2xl leading-none">Josef Kvapil</span>
    </a>
    <button
      id="nav-close"
      type="button"
      class="label-mono cursor-pointer text-muted transition-colors hover:text-accent"
    >
      {t('nav.close')} ×
    </button>
  </div>

  <nav
    class="flex flex-1 flex-col justify-center px-(--spacing-gutter)"
    aria-label="Main"
  >
    {
      items.map((item, i) => (
        <a
          href={item.href}
          class="index-item flex items-baseline gap-5 border-b border-dashed border-hairline py-5 text-ink no-underline"
          style={`--i: ${i}`}
        >
          <span class="label-mono text-accent" aria-hidden="true">{num(i)}</span>
          <span class="font-display text-4xl">{t(item.key)}</span>
        </a>
      ))
    }
  </nav>

  <!-- title block -->
  <div
    class="label-mono index-item mx-(--spacing-gutter) mb-6 flex items-center justify-between gap-4 border-t border-dashed border-hairline pt-5 text-muted"
    style={`--i: ${items.length}`}
  >
    <span aria-hidden="true">JK · jkvapil.cz</span>
    <div class="flex items-center gap-5">
      <a
        href={langTarget}
        hreflang={lang === 'en' ? 'cs' : 'en'}
        lang={lang === 'en' ? 'cs' : 'en'}
        class="text-muted transition-colors hover:text-accent"
      >
        {t('nav.langSwitch')}
      </a>
      <button
        type="button"
        data-theme-toggle
        class="cursor-pointer text-muted transition-colors hover:text-accent"
        aria-pressed="false"
      >
        <span class="dark:hidden">dark</span>
        <span class="hidden dark:inline">light</span>
        <span class="sr-only">{t('nav.themeToggle')}</span>
      </button>
    </div>
  </div>
</div>

<style>
  header nav a,
  #brandbar nav a {
    position: relative;
  }
  header nav a::after,
  #brandbar nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.2em;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  header nav a:hover::after,
  header nav a:focus-visible::after,
  #brandbar nav a:hover::after,
  #brandbar nav a:focus-visible::after {
    transform: scaleX(1);
  }
  /* the drafting number sits outside the underline */
  header nav a .num,
  #brandbar nav a .num {
    margin-right: 0.35em;
  }
  header nav a:has(.num)::after,
  #brandbar nav a:has(.num)::after {
    left: 1.6em;
    width: calc(100% - 1.6em);
  }

  #nav-index[data-open] {
    display: flex;
  }
  #nav-index .index-item {
    opacity: 0;
    transform: translateY(0.75rem);
  }
  #nav-index[data-open] .index-item {
    animation: index-rise 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i) * 60ms);
  }
  @keyframes index-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }
  #nav-index .index-item:hover .font-display {
    color: var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    header nav a::after,
    #brandbar nav a::after {
      transition: none;
    }
    #nav-index[data-open] .index-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // slim brand strip slides in once the masthead is gone; hysteresis so
  // snap jitter near the top never leaves it flickering
  const brandbar = document.getElementById('brandbar');
  const syncScrolled = () => {
    if (!brandbar) return;
    const y = window.scrollY;
    if (y > 96) brandbar.dataset.visible = '';
    else if (y < 48) delete brandbar.dataset.visible;
  };
  syncScrolled();
  window.addEventListener('scroll', syncScrolled, { passive: true });

  // theme: one handler for every toggle (desktop row + mobile title block)
  const toggles = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');
  const syncPressed = () => {
    const pressed = String(document.documentElement.dataset.theme === 'dark');
    toggles.forEach((el) => el.setAttribute('aria-pressed', pressed));
  };
  syncPressed();
  toggles.forEach((el) =>
    el.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch {}
      syncPressed();
    }),
  );

  // mobile index overlay — openable from the masthead and the brand strip
  const overlay = document.getElementById('nav-index');
  const openBtns = document.querySelectorAll<HTMLButtonElement>('[data-nav-open]');
  const closeBtn = document.getElementById('nav-close');
  let lastOpener: HTMLButtonElement | null = null;

  const setOpen = (open: boolean, opener?: HTMLButtonElement) => {
    if (!overlay) return;
    if (open) {
      overlay.dataset.open = '';
      lastOpener = opener ?? lastOpener;
    } else {
      delete overlay.dataset.open;
    }
    overlay.classList.toggle('hidden', !open);
    document.documentElement.classList.toggle('overflow-hidden', open);
    openBtns.forEach((b) => b.setAttribute('aria-expanded', String(open)));
    if (open) {
      closeBtn?.focus();
    } else {
      lastOpener?.focus();
    }
  };

  // keep Tab inside the modal while it is open
  overlay?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || overlay.dataset.open === undefined) return;
    const focusables = overlay.querySelectorAll<HTMLElement>('a[href], button');
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  openBtns.forEach((b) => b.addEventListener('click', () => setOpen(true, b)));
  closeBtn?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.dataset.open !== undefined) setOpen(false);
  });
  overlay?.querySelectorAll('a[href^="#"]').forEach((a) =>
    a.addEventListener('click', () => setOpen(false)),
  );
</script>
